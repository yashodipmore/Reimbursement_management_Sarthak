{
  "info": {
    "name": "Expense Management System (Master Collection)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete production-ready collection for 3-tier roles. Includes: Admin, Manager, Employee, AI Fraud Detection, AI OCR Scanning, and Advanced Analytics."
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "ADMIN_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "MANAGER_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "EMPLOYEE_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "EXPENSE_ID",
      "value": "1",
      "type": "string"
    },
    {
      "key": "USER_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "MANAGER_USER_ID",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth & Onboarding",
      "item": [
        {
          "name": "1. Register Admin (First Signup)",
          "description": "Creates Company + Admin. Token is saved automatically.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json(); if(r.token) pm.collectionVariables.set('ADMIN_TOKEN', r.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"LogiCorp\",\n  \"name\": \"Admin User\",\n  \"email\": \"admin@logicorp.com\",\n  \"password\": \"password123\",\n  \"country\": \"India\",\n  \"currency\": \"INR\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "2. Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json(); if(r.token) pm.collectionVariables.set('ADMIN_TOKEN', r.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@logicorp.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json(); if(r.token) pm.collectionVariables.set('MANAGER_TOKEN', r.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@logicorp.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json(); if(r.token) pm.collectionVariables.set('EMPLOYEE_TOKEN', r.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rcpit2028@gmail.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin Panel",
      "item": [
        {
          "name": "📁 User Management",
          "item": [
            {
              "name": "Create Manager",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var r = pm.response.json(); if(r.user) pm.collectionVariables.set('MANAGER_USER_ID', r.user.id);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{ADMIN_TOKEN}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Jay Manager\",\n  \"email\": \"manager@logicorp.com\",\n  \"password\": \"password123\",\n  \"role\": \"manager\"\n}"
                },
                "url": {
                  "raw": "{{BASE_URL}}/api/users",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "api",
                    "users"
                  ]
                }
              }
            },
            {
              "name": "Create Employee (Assigned to Manager)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var r = pm.response.json(); if(r.user) pm.collectionVariables.set('USER_ID', r.user.id);"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{ADMIN_TOKEN}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"John Emp\",\n  \"email\": \"rcpit2028@gmail.com\",\n  \"password\": \"password123\",\n  \"role\": \"employee\",\n  \"manager_id\": \"{{MANAGER_USER_ID}}\"\n}"
                },
                "url": {
                  "raw": "{{BASE_URL}}/api/users",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "api",
                    "users"
                  ]
                }
              }
            },
            {
              "name": "List All Users",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{ADMIN_TOKEN}}"
                  }
                ],
                "url": {
                  "raw": "{{BASE_URL}}/api/users",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "api",
                    "users"
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "📁 AI Dashboard & Analytics",
          "item": [
            {
              "name": "1. Full Company Summary (+Forecast)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{ADMIN_TOKEN}}"
                  }
                ],
                "url": {
                  "raw": "{{BASE_URL}}/api/analytics/company",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "api",
                    "analytics",
                    "company"
                  ]
                }
              }
            },
            {
              "name": "2. View AI Flagged Fraud",
              "description": "See all expenses flagged for duplicate or anomalies",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{ADMIN_TOKEN}}"
                  }
                ],
                "url": {
                  "raw": "{{BASE_URL}}/api/expenses/all?is_flagged=true",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "api",
                    "expenses",
                    "all"
                  ],
                  "query": [
                    {
                      "key": "is_flagged",
                      "value": "true"
                    }
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "📁 Approval Rules",
          "item": [
            {
              "name": "Create Rule (Manager Auto-Approval)",
              "description": "Forces a rule where Employee's manager must approve first.",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{ADMIN_TOKEN}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Standard Flow\",\n  \"is_manager_approver\": true,\n  \"steps\": [\n    {\n      \"step_order\": 1,\n      \"approver_id\": \"{{ADMIN_USER_ID}}\",\n      \"label\": \"Final Admin Review\"\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{BASE_URL}}/api/approvals/flows",
                  "host": [
                    "{{BASE_URL}}"
                  ],
                  "path": [
                    "api",
                    "approvals",
                    "flows"
                  ]
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "👔 Manager Workspace",
      "item": [
        {
          "name": "My Team Stats (Analytics)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{MANAGER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/analytics/my-team",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "analytics",
                "my-team"
              ]
            }
          }
        },
        {
          "name": "Pending for My Action",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{MANAGER_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/approvals/pending",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "approvals",
                "pending"
              ]
            }
          }
        },
        {
          "name": "Action: Approve/Reject",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{MANAGER_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"APPROVE\",\n  \"comment\": \"Verified by manager\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/approvals/{{EXPENSE_ID}}/action",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "approvals",
                "{{EXPENSE_ID}}",
                "action"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "👤 Employee Workspace",
      "item": [
        {
          "name": "1. 📸 AI Scan Receipt (OCR)",
          "description": "Upload an image of a receipt to automatically extract details.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{EMPLOYEE_TOKEN}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "receipt",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{BASE_URL}}/api/expenses/ocr",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "expenses",
                "ocr"
              ]
            }
          }
        },
        {
          "name": "2. Submit Expense",
          "description": "Use data extracted from OCR to submit here.",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{EMPLOYEE_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bistro Cafe\",\n  \"amount\": 45.2,\n  \"currency\": \"USD\",\n  \"category\": \"food\",\n  \"date\": \"2026-03-29\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/expenses",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "expenses"
              ]
            }
          }
        },
        {
          "name": "My Expenses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{EMPLOYEE_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/expenses/mine",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "expenses",
                "mine"
              ]
            }
          }
        }
      ]
    }
  ]
}